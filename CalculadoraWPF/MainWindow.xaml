<Window x:Class="CalculadoraWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculadoraWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="622" Width="413">

    <Window.Resources>

        <!-- Estilo Botones -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="70"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pantalla -->
        <Border Grid.Row="0"
                Background="#2D2D2D"
                CornerRadius="20"
                Padding="10"
                Margin="5">

            <TextBox x:Name="txtPantalla"
                     Text="0"
                     FontSize="42"
                     Foreground="White"
                     Background="#2D2D2D"
                     BorderThickness="0"
                     HorizontalContentAlignment="Right"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"/>
        </Border>

        <!-- Botones -->
        <UniformGrid Grid.Row="1"
                     Rows="5"
                     Columns="4"
                     Margin="5">

            <Button Content="C"
                    Background="#FF595E"
                    Click="BtnLimpiar_Click"/>

            <Button Content="/"
                    Background="#FF924C"
                    Click="Operador_Click"/>

            <Button Content="*"
                    Background="#FF924C"
                    Click="Operador_Click"/>

            <Button Content="-"
                    Background="#FF924C"
                    Click="Operador_Click"/>

            <Button Content="7"
                    Click="Numero_Click"/>

            <Button Content="8"
                    Click="Numero_Click"/>

            <Button Content="9"
                    Click="Numero_Click"/>

            <Button Content="+"
                    Background="#FF924C"
                    Click="Operador_Click"/>

            <Button Content="4"
                    Click="Numero_Click"/>

            <Button Content="5"
                    Click="Numero_Click"/>

            <Button Content="6"
                    Click="Numero_Click"/>

            <Button Content="="
                    Background="#4CAF50"
                    Click="BtnResultado_Click"/>

            <Button Content="1"
                    Click="Numero_Click"/>

            <Button Content="2"
                    Click="Numero_Click"/>

            <Button Content="3"
                    Click="Numero_Click"/>

            <Button Content="0"
                    Click="Numero_Click"/>

        </UniformGrid>

    </Grid>

</Window>